# Aimport pygame
import random
import os

pygame.init()

WIDTH, HEIGHT = 800, 400
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Ninja Runner - AAA Edition")

clock = pygame.time.Clock()

# Colors
WHITE = (240, 240, 240)
BLACK = (0, 0, 0)
RED = (255, 80, 80)
SKY1 = (15, 15, 35)
SKY2 = (30, 30, 70)
SKY3 = (60, 60, 120)
GROUND = (50, 50, 50)
GREEN = (70, 200, 70)
GOLD = (255, 210, 90)

font = pygame.font.SysFont(None, 32)

# Save system
SAVE_FILE = "highscore.txt"

def load_score():
    if os.path.exists(SAVE_FILE):
        with open(SAVE_FILE, "r") as f:
            return int(f.read())
    return 0

def save_score(score):
    with open(SAVE_FILE, "w") as f:
        f.write(str(score))

high_score = load_score()

# Player
x = 120
y = 300
size = 40

vy = 0
gravity = 0.75
jump_power = -14
on_ground = True

ground_y = 340

# Dash
dash_speed = 14
is_dashing = False
dash_timer = 0

# Animation
frame = 0
anim_tick = 0

# World
obstacles = []
trees = []
particles = []

spawn_timer = 0
tree_timer = 0
speed = 6

# Parallax layers
bg1 = 0
bg2 = 0
bg3 = 0

state = "start"
score = 0

# ---------------- FUNCTIONS ---------------- #

def reset():
    global y, vy, on_ground, obstacles, particles, score, speed, is_dashing
    y = 300
    vy = 0
    on_ground = True
    obstacles.clear()
    particles.clear()
    score = 0
    speed = 6
    is_dashing = False

def spawn_particles(x, y):
    for _ in range(10):
        particles.append([x, y, random.randint(-2, 2), random.randint(-3, 0), 20])

def draw_background():
    global bg1, bg2, bg3

    screen.fill(SKY1)

    bg1 -= speed * 0.2
    bg2 -= speed * 0.4
    bg3 -= speed * 0.6

    pygame.draw.rect(screen, SKY2, (bg1 % WIDTH - WIDTH, 0, WIDTH, HEIGHT))
    pygame.draw.rect(screen, SKY2, (bg1 % WIDTH, 0, WIDTH, HEIGHT))

    pygame.draw.rect(screen, SKY3, (bg2 % WIDTH - WIDTH, 0, WIDTH, HEIGHT))
    pygame.draw.rect(screen, SKY3, (bg2 % WIDTH, 0, WIDTH, HEIGHT))

def draw_ground():
    pygame.draw.rect(screen, GROUND, (0, ground_y + size, WIDTH, HEIGHT))

def draw_tree(x, y):
    pygame.draw.rect(screen, (120, 80, 40), (x, y - 30, 10, 30))
    pygame.draw.circle(screen, GREEN, (x + 5, y - 40), 18)

def draw_ninja(x, y, frame, jumping, dashing):
    body = (30, 30, 30)
    glow = GOLD if dashing else WHITE

    pygame.draw.rect(screen, body, (x, y, 40, 40))
    pygame.draw.rect(screen, (180, 180, 180), (x, y, 40, 10))

    pygame.draw.circle(screen, glow, (x + 12, y + 20), 3)
    pygame.draw.circle(screen, glow, (x + 28, y + 20), 3)

    if jumping:
        pygame.draw.line(screen, glow, (x + 10, y + 40), (x + 5, y + 55), 2)
        pygame.draw.line(screen, glow, (x + 30, y + 40), (x + 35, y + 55), 2)
    else:
        offset = 5 if frame == 0 else 0
        pygame.draw.line(screen, glow, (x + 10, y + 40), (x + 5, y + 50 + offset), 2)
        pygame.draw.line(screen, glow, (x + 30, y + 40), (x + 35, y + 50 - offset), 2)

# ---------------- GAME LOOP ---------------- #

running = True
while running:
    clock.tick(60)

    draw_background()
    draw_ground()

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

        if event.type == pygame.KEYDOWN:

            if state == "start":
                if event.key == pygame.K_SPACE:
                    state = "play"

            elif state == "play":

                if event.key == pygame.K_SPACE and on_ground:
                    vy = jump_power
                    on_ground = False
                    spawn_particles(x, y)

                if event.key == pygame.K_LSHIFT and on_ground:
                    is_dashing = True
                    dash_timer = 15

            elif state == "gameover":
                if event.key == pygame.K_r:
                    state = "play"
                    reset()

    if state == "play":

        # Dash logic
        if is_dashing:
            speed = dash_speed
            dash_timer -= 1
            if dash_timer <= 0:
                is_dashing = False
        else:
            speed += 0.002

        # Gravity
        vy += gravity
        y += vy

        if y >= ground_y:
            y = ground_y
            if not on_ground:
                spawn_particles(x, y)
            vy = 0
            on_ground = True

        # Obstacles
        spawn_timer += 1
        if spawn_timer > 65:
            obstacles.append([WIDTH, ground_y])
            spawn_timer = 0

        for o in obstacles:
            o[0] -= speed

        obstacles = [o for o in obstacles if o[0] > -50]

        # Trees
        tree_timer += 1
        if tree_timer > 80:
            trees.append([WIDTH + random.randint(0, 200), ground_y + 10])
            tree_timer = 0

        for t in trees:
            t[0] -= speed * 0.5

        trees = [t for t in trees if t[0] > -50]

        # Collision
        player_rect = pygame.Rect(x, y, size, size)

        for o in obstacles:
            if player_rect.colliderect(pygame.Rect(o[0], o[1], 30, 40)):
                state = "gameover"
                if score > high_score:
                    save_score(score)

        score += 1

        # Animation
        anim_tick += 1
        if anim_tick > 6:
            frame = 1 - frame
            anim_tick = 0

    # Particles
    for p in particles:
        p[0] += p[2]
        p[1] += p[3]
        p[4] -= 1
    particles = [p for p in particles if p[4] > 0]

    # Draw trees
    for t in trees:
        draw_tree(t[0], t[1])

    # Draw obstacles
    for o in obstacles:
        pygame.draw.rect(screen, RED, (o[0], o[1], 30, 40))

    # Draw ninja
    draw_ninja(x, y, frame, not on_ground, is_dashing)

    # Particles
    for p in particles:
        pygame.draw.circle(screen, WHITE, (int(p[0]), int(p[1])), 3)

    # UI
    screen.blit(font.render(f"Score: {score}", True, WHITE), (10, 10))
    screen.blit(font.render(f"High: {high_score}", True, WHITE), (10, 40))

    if state == "start":
        screen.blit(font.render("SPACE to Start", True, WHITE), (300, 180))

    if state == "gameover":
        screen.blit(font.render("GAME OVER - R to Restart", True, RED), (250, 180))

    pygame.display.flip()

pygame.quit()
